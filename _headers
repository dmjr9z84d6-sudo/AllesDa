# Netlify-Cache-Konfiguration fuer AllesDa
# Erzwingt, dass der Browser AllesDa.js bei jedem Aufruf gegencheckt,
# damit Updates wirklich beim Nutzer ankommen.
/AllesDa.js
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate
